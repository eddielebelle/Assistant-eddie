# Eddie Voice Assistant Configuration

# MQTT (IoT/Smart Home only)
MQTT_HOST=192.168.1.57
MQTT_PORT=1883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password

# Spotify
# Get credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8000
SPOTIFY_DATA_PATH=./resources/spotify_data.json

# OpenWeatherMap
# Get your API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Whisper STT
WHISPER_MODEL_PATH=
WHISPER_MODEL_SIZE=small.en

# TTS
TTS_SPEAKER_INDEX=80
TTS_MODEL_NAME=tts_models/en/vctk/vits

# Agent
AGENT_PORT=5000
MAX_HISTORY_MESSAGES=50
SESSION_IDLE_TIMEOUT=300

# Resources
ALARM_SOUND_PATH=./resources/alarm1.wav
