# Eddie Voice Assistant Configuration

# MQTT (IoT/Smart Home only)
MQTT_HOST=192.168.1.57
MQTT_PORT=1883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password

# Spotify
# Get credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8000
SPOTIFY_DATA_PATH=./resources/spotify_data.json

# OpenWeatherMap
# Get your API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# STT (faster-whisper)
WHISPER_MODEL_SIZE=small.en
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=default

# Wake word (openwakeword)
# Path to custom .onnx model, or leave blank to use bundled models
WAKE_WORD_MODEL=
WAKE_WORD_THRESHOLD=0.5

# TTS - choose backend: "kokoro", "chatterbox", or "coqui"
TTS_BACKEND=kokoro

# Kokoro voices: bf_* = British female, bm_* = British male, af_* = American female, am_* = American male
# British: bf_emma, bf_isabella, bf_alice, bf_lily, bm_george, bm_lewis, bm_daniel, bm_fable
# American: af_heart, af_bella, af_nicole, af_sarah, am_adam, am_michael, am_echo
TTS_KOKORO_VOICE=bf_emma
TTS_KOKORO_LANG=b

# Chatterbox - provide a 5-10s reference audio clip for voice cloning (optional)
TTS_CHATTERBOX_REF_AUDIO=

# Legacy Coqui VITS (deprecated)
# TTS_COQUI_SPEAKER_INDEX=80
# TTS_COQUI_MODEL_NAME=tts_models/en/vctk/vits

# Agent
AGENT_HOST=localhost
AGENT_PORT=5000
MAX_HISTORY_MESSAGES=50
SESSION_IDLE_TIMEOUT=300

# Resources
ALARM_SOUND_PATH=./resources/alarm1.wav
